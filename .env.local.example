# Aegis — Frontend (Next.js) environment variables
# Copy this file to .env.local and fill in real values:
#   cp .env.local.example .env.local
#
# .env.local is gitignored by Next.js by default and must never be committed.

# ── Gemini vision (server-side detection) ─────────────────────────────────────
# Required. Detection runs via Google's Gemini API in app/api/gemini/route.ts.
# The key stays server-side; the browser never sees it. Billed per request.
GEMINI_API_KEY=
# Optional overrides:
# GEMINI_MODEL=gemini-2.5-flash

# ── Node camera service (ONVIF discovery + RTSP relay) ────────────────────────
# HTTP base for the discovery API (run: npm run dev:camera-service).
CAMERA_SERVICE_ORIGIN=http://localhost:3001
NEXT_PUBLIC_CAMERA_SERVICE_HTTP=http://localhost:3001
NEXT_PUBLIC_CAMERA_SERVICE_WS=ws://localhost:3001

# ── FFmpeg (RTSP → MJPEG decoding) ────────────────────────────────────────────
# The stream routes shell out to ffmpeg. Leave unset to use `ffmpeg` on PATH,
# or point at an explicit binary.
# FFMPEG_PATH=ffmpeg

# ── RTSP password fallbacks ───────────────────────────────────────────────────
# When a camera rejects the embedded password with 401, /api/stream/rtsp retries
# these passwords in order (comma-separated). Default: 123456,hk123456
# RTSP_PASSWORDS=123456,hk123456

# When a camera returns 404 for the RTSP path, /api/stream/rtsp retries these
# paths in order (comma-separated). Default covers Hikvision/Dahua/generic.
# RTSP_PATHS=/Streaming/Channels/101,/Streaming/Channels/102,/live,/h264,/cam/realmonitor?channel=1&subtype=0,/stream2,/video1

# ── Static export mode ────────────────────────────────────────────────────────
# Set to "1" to enable Next.js static export (disables API rewrites).
# Leave unset for standard server-side rendering with API proxying.
STATIC_EXPORT=
